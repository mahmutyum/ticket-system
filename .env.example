# =====================================================================
# IT Ticket System — environment configuration
# Coolify: tüm değerler panelden düzenlenebilir.
# Yerel: `cp .env.example .env` ve değerleri doldur.
# =====================================================================

# ==================== APP / FQDN ====================
# NPM (Nginx Proxy Manager) arkasında kullanılan domain(ler).
# Birden fazla FQDN için virgülle ayır. CORS bu listeyi whitelist olarak alır.
# Örn: APP_URL=https://ticket.firma.com,https://destek.firma.com
APP_URL=https://ticket.company.com
APP_NAME=IT Destek Sistemi

# ==================== HOST PORTLARI ====================
# NPM bu porta forward edecek. Lokal: http://localhost:1111
FRONTEND_PORT=1111

# Backend host port (genelde NPM doğrudan frontend'e gider; backend'i dışa
# açmak istemiyorsan bunu boş bırakma — sadece debug için kullan).
BACKEND_PORT=4000

# Dahili nginx proxy (opsiyonel, --profile proxy ile aktif olur).
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# PgAdmin (--profile tools ile aktif olur).
PGADMIN_PORT=5050

# ==================== YEREL ARAÇ ERİŞİMİ (Opsiyonel) ====================
# DBeaver/RedisInsight gibi araçlarla bağlanmak için aşağıdaki override'ı
# çalıştır:  docker compose -f docker-compose.yml -f docker-compose.local.yml up
# Production'da (Coolify) ASLA expose etme — bu dosyayı kullanma.
DB_PORT=5432
REDIS_PORT=6379

# ==================== DATABASE ====================
DB_NAME=ticketdb
DB_USER=ticket
DB_PASSWORD=changeme_db_password
DATABASE_URL=postgresql://ticket:changeme_db_password@postgres:5432/ticketdb

# ==================== REDIS ====================
# REDIS_PASSWORD hem redis container'ını başlatırken (--requirepass) hem de
# REDIS_URL içinde kullanılır. İki yerde de AYNI değeri yaz.
REDIS_PASSWORD=changeme_redis_password
REDIS_URL=redis://:changeme_redis_password@redis:6379

# ==================== BACKEND ====================
NODE_ENV=production
PORT=4000

# JWT imza anahtarları — en az 32 karakter, birbirinden FARKLI olmalı.
# Üret:  openssl rand -base64 48
JWT_SECRET=changeme_jwt_secret_min_32_chars_long
JWT_REFRESH_SECRET=changeme_jwt_refresh_secret_min_32
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d

# Şifre kasası (/staff/passwords) için AES-256-GCM anahtarı.
# TAM 64 hex karakter (32 byte, sadece 0-9a-f) olmalı — yoksa backend açılışta durur.
# Üret:  openssl rand -hex 32
#
# Uygulama hem uzunluğu hem hex karakter kümesini açılışta doğrular.
#
# UYARI: Bu anahtarı kaybedersen veya değiştirirsen kasadaki TÜM kayıtlı
# şifreler kalıcı olarak çözülemez hale gelir. Yedekle.
# ROTASYON: Anahtarı güvenli şekilde değiştirmek için önce eski değeri
# CREDENTIALS_ENC_KEY_OLD olarak verip re-encrypt script'ini çalıştır:
#   docker compose exec backend npx tsx prisma/scripts/rotate-credentials-key.ts --commit
CREDENTIALS_ENC_KEY=changeme_run_openssl_rand_hex_32

# Ayrıcalıklı hesaplarda (admin/it_manager) MFA kurulu değilse panelde uyarı
# göster. Zorunluluk değil, sadece hatırlatma. Kapatmak için 'false'.
MFA_WARNING_ENABLED=true

# API dokümantasyonu (Swagger UI, /docs). Tüm endpoint listesini yayınlar.
# İç ağda kabul edilebilir; internete açık bir kurulumda 'false' yap.
ENABLE_API_DOCS=true

# Kaç reverse proxy hop'una güvenilecek. RATE LIMITING'İN TAMAMI BUNA BAĞLIDIR.
# Backend'e en yakından sayılır:
#   1 → yalnızca frontend nginx (dahili proxy profili veya doğrudan erişim)
#   2 → NPM/Coolify + frontend nginx  ← standart production topolojisi
#
# Fazla vermek TEHLİKELİDİR: istemcinin gönderdiği X-Forwarded-For'a güvenilir ve
# saldırgan her istekte taze bir rate-limit kovası alarak login brute force'u
# sınırsız hale getirir. Az vermek yalnızca hassasiyeti düşürür (herkes proxy'nin
# IP'sinden görünür, limitler ortak kovaya düşer).
#
# Emin değilsen düşük tut. Doğrulamak için: bir isteğe sahte
# `X-Forwarded-For: 1.2.3.4` ekle; audit log'da veya rate-limit davranışında
# 1.2.3.4 görünüyorsa değer fazladır.
TRUST_PROXY=2

# ==================== SMTP (Global / Fallback) ====================
SMTP_HOST=smtp.company.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@company.com
SMTP_PASS=changeme_smtp_password
SMTP_FROM=IT Destek <noreply@company.com>

# ==================== SMS Gateway (Optional) ====================
SMS_GATEWAY_URL=
SMS_GATEWAY_API_KEY=
SMS_SENDER=IT_DESTEK

# ==================== FILE UPLOAD ====================
MAX_FILE_SIZE=26214400
UPLOAD_DIR=/app/uploads
# Kapanış tarihi bu süreden eski resolved/closed ticket ekleri retention işiyle silinir.
RETENTION_CLOSED_TICKET_DAYS=365

# ==================== TOOLS (Optional) ====================
PGADMIN_EMAIL=admin@company.com
PGADMIN_PASSWORD=changeme_pgadmin_password
