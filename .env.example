# =====================================================================
# IT Ticket System — environment configuration
# Coolify: tüm değerler panelden düzenlenebilir.
# Yerel: `cp .env.example .env` ve değerleri doldur.
# =====================================================================

# ==================== APP / FQDN ====================
# NPM (Nginx Proxy Manager) arkasında kullanılan domain(ler).
# Birden fazla FQDN için virgülle ayır. CORS bu listeyi whitelist olarak alır.
# Örn: APP_URL=https://ticket.firma.com,https://destek.firma.com
APP_URL=https://ticket.company.com
APP_NAME=IT Destek Sistemi

# ==================== HOST PORTLARI ====================
# NPM bu porta forward edecek. Lokal: http://localhost:1111
FRONTEND_PORT=1111

# Backend host port (genelde NPM doğrudan frontend'e gider; backend'i dışa
# açmak istemiyorsan bunu boş bırakma — sadece debug için kullan).
BACKEND_PORT=4000

# Dahili nginx proxy (opsiyonel, --profile proxy ile aktif olur).
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# PgAdmin (--profile tools ile aktif olur).
PGADMIN_PORT=5050

# ==================== YEREL ARAÇ ERİŞİMİ (Opsiyonel) ====================
# DBeaver/RedisInsight gibi araçlarla bağlanmak için aşağıdaki override'ı
# çalıştır:  docker compose -f docker-compose.yml -f docker-compose.local.yml up
# Production'da (Coolify) ASLA expose etme — bu dosyayı kullanma.
DB_PORT=5432
REDIS_PORT=6379

# ==================== DATABASE ====================
DB_NAME=ticketdb
DB_USER=ticket
DB_PASSWORD=changeme_db_password
DATABASE_URL=postgresql://ticket:changeme_db_password@postgres:5432/ticketdb

# ==================== REDIS ====================
REDIS_PASSWORD=changeme_redis_password
REDIS_URL=redis://:changeme_redis_password@redis:6379

# ==================== BACKEND ====================
NODE_ENV=production
PORT=4000
JWT_SECRET=changeme_jwt_secret_min_32_chars_long
JWT_REFRESH_SECRET=changeme_jwt_refresh_secret_min_32
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d

# ==================== SMTP (Global / Fallback) ====================
SMTP_HOST=smtp.company.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@company.com
SMTP_PASS=changeme_smtp_password
SMTP_FROM=IT Destek <noreply@company.com>

# ==================== SMS Gateway (Optional) ====================
SMS_GATEWAY_URL=
SMS_GATEWAY_API_KEY=
SMS_SENDER=IT_DESTEK

# ==================== FILE UPLOAD ====================
MAX_FILE_SIZE=26214400
UPLOAD_DIR=/app/uploads

# ==================== TOOLS (Optional) ====================
PGADMIN_EMAIL=admin@company.com
PGADMIN_PASSWORD=changeme_pgadmin_password
