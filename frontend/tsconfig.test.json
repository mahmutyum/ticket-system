// Testler için tip kontrolü.
//
// Ana tsconfig.json yalnızca `src`'yi include eder, yani `tests/` HİÇ kontrol
// edilmez ve `npm run typecheck` testlerde tip hatası olsa bile yeşil döner.
// (Backend'de tam olarak bu tuzağa düşülmüştü: typecheck:tests testleri hiç
// görmüyordu.)
//
// Çalıştır: npm run typecheck:tests
{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "types": ["vitest/globals", "node", "@testing-library/jest-dom"]
  },
  "include": ["src", "tests", "vitest.config.ts"],
  "exclude": ["node_modules", "dist"]
}
