// Testler için tip kontrolü.
//
// Ana tsconfig.json `rootDir: "src"` ile derleme yapar ve `tests`'i dışlar —
// testleri oraya eklemek build çıktısını bozar. Bu dosya yalnızca tip kontrolü
// yapar (noEmit), bir şey üretmez.
//
// Çalıştır: npm run typecheck:tests
{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "rootDir": ".",
    "declaration": false,
    "declarationMap": false,
    "types": ["node"]
  },
  "include": ["src/**/*", "tests/**/*", "vitest.config.ts", "vitest.integration.config.ts"],
  // exclude MİRAS ALINIR ve include'u filtreler: ana tsconfig `"tests"` dışlar,
  // burada ezilmezse test dosyaları sessizce kontrol dışı kalır — komut yeşil
  // görünür ama hiçbir testi kontrol etmemiş olur.
  "exclude": ["node_modules", "dist"]
}
